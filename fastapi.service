[Unit]
Description=Aplicacion FastAPI para el final de Sistemas Operativos
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/fastapi-ec2
# Ajusta esta ruta dependiendo de donde esté tu entorno virtual (venv)
ExecStart=/home/ubuntu/fastapi-ec2/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target